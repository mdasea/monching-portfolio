}`;

const heygenApi = `POST https://api.heygen.com/v2/video/generate
Authorization: Bearer {{api_key}}

{
  "video_inputs": [{
    "character": { "type": "avatar", "avatar_id": "avatar_id" },
    "voice": { "type": "text", "input_text": "Hello world!" }
  }]
}`;

const extractPipeline = `async function extractPipeline(url: string) {
  const res = await fetch(url);
  const html = await res.text();
  const text = html.replace(/<[^>]*>/g, '');

  const result = await openai.chat.completions.create({
    model: 'gpt-4o',
    messages: [{
      role: 'user',
      content: \`Extract structured data:\\n\${text.slice(0, 8000)}\`,
    }],
    response_format: { type: 'json_object' },
  });

  const data = JSON.parse(result.choices[0].message.content);
  await db.insert(data);
  return data;
}`;

const prReview = `async function reviewPR(patch: string) {
  const res = await openai.chat.completions.create({
    model: 'gpt-4o',
    messages: [
      { role: 'system', content: 'Review code changes. Flag bugs, security issues, and style problems.' },
      { role: 'user', content: \`Review this diff:\\n\${patch}\` },
    ],
  });

  const review = res.choices[0].message.content;
  await fetch(\`https://api.github.com/repos/owner/repo/issues/\${pr}/comments\`, {
    method: 'POST',
    headers: { Authorization: \`Bearer \${ghToken}\` },
    body: JSON.stringify({ body: review }),
  });
}`;

const contentSummary = `async function summarize(longText: string) {
  const chunks = chunkText(longText, 2000);
  const summaries: string[] = [];

  for (const chunk of chunks) {
    const res = await openai.chat.completions.create({
      model: 'gpt-4o-mini',
      messages: [{
        role: 'user',
        content: \`Summarize concisely:\\n\${chunk}\`,
      }],
      max_tokens: 200,
    });
    summaries.push(res.choices[0].message.content);
  }

  const res = await openai.chat.completions.create({
    model: 'gpt-4o',
    messages: [{
      role: 'user',
      content: \`Combine these summaries:\\n\${summaries.join('\\n\\n')}\`,
    }],
  });
  return res.choices[0].message.content;
}`;

