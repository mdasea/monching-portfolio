const lovableWhat = `Lovable.dev is an AI-powered IDE that generates
full-stack web applications from natural language prompts.
It combines a chat interface, visual editor, and built-in
infrastructure (Supabase, Netlify) for rapid app development.

Think of it as an AI development platform where you describe
what you want to build, and it generates the entire stack —
frontend, backend, database, auth, deployment — instantly.

KEY FEATURES:
- Natural language to working app in minutes
- Built-in Supabase (auth, PostgreSQL, storage)
- Visual drag-and-drop editor for UI
- Automatic GitHub repo creation per project
- One-click deploy via Netlify
- Iterative editing through chat prompts
- Real-time preview as you build`;

const lovableStart = `1. Go to https://lovable.dev and sign in with GitHub

2. Click "Create new project"

3. Describe your app in natural language:
   "A project management app with kanban boards,
    team workspaces, task assignments, and
    real-time activity feed"

4. Lovable generates the full app instantly

5. Refine with follow-up prompts:
   "Add drag-and-drop to reorder tasks"
   "Change the color scheme to indigo"
   "Add a comments section to each task"`;

const lovablePrompts = `# Tips for better results

START WITH A CLEAR VISION
Write a detailed spec before generating:
"Build a habit tracker with daily check-ins,
 streak tracking, social leaderboard, and
 push notifications via email"

BUILD INCREMENTALLY
Focus on one feature at a time rather than
trying to build everything at once.

BE SPECIFIC WITH FIXES
Instead of "Fix the layout", try:
"Make the sidebar collapsible with a toggle
 button at the top, and center the main
 content when sidebar is closed"

USE THE VISUAL EDITOR
For UI tweaks, use Lovable's visual editor
to drag and adjust elements directly.

REVIEW GENERATED CODE
Check the code Lovable produces — it's a
great way to learn and catch issues early.`;

const lovableSupabase = `Lovable has built-in Supabase integration.

When you create a project, you can:
- Enable Supabase auth (magic link, OAuth)
- Create database tables from prompts
  "Add a tasks table with title, status, assignee"
- Set up Row Level Security policies
- Use Supabase storage for file uploads
- Query data via the auto-generated API

You can also connect your own Supabase project
for more control over the schema and settings.`;

const extractPipeline = `async function extractPipeline(url: string) {
  const res = await fetch(url);
  const html = await res.text();
  const text = html.replace(/<[^>]*>/g, '');

  const result = await openai.chat.completions.create({
    model: 'gpt-4o',
    messages: [{
      role: 'user',
      content: \`Extract structured data:\\n\${text.slice(0, 8000)}\`,
    }],
    response_format: { type: 'json_object' },
  });

  const data = JSON.parse(result.choices[0].message.content);
  await db.insert(data);
  return data;
}`;

const prReview = `async function reviewPR(patch: string) {
  const res = await openai.chat.completions.create({
    model: 'gpt-4o',
    messages: [
      { role: 'system', content: 'Review code changes. Flag bugs, security issues, and style problems.' },
      { role: 'user', content: \`Review this diff:\\n\${patch}\` },
    ],
  });

  const review = res.choices[0].message.content;
  await fetch(\`https://api.github.com/repos/owner/repo/issues/\${pr}/comments\`, {
    method: 'POST',
    headers: { Authorization: \`Bearer \${ghToken}\` },
    body: JSON.stringify({ body: review }),
  });
}`;

const contentSummary = `async function summarize(longText: string) {
  const chunks = chunkText(longText, 2000);
  const summaries: string[] = [];

  for (const chunk of chunks) {
    const res = await openai.chat.completions.create({
      model: 'gpt-4o-mini',
      messages: [{
        role: 'user',
        content: \`Summarize concisely:\\n\${chunk}\`,
      }],
      max_tokens: 200,
    });
    summaries.push(res.choices[0].message.content);
  }

  const res = await openai.chat.completions.create({
    model: 'gpt-4o',
    messages: [{
      role: 'user',
      content: \`Combine these summaries:\\n\${summaries.join('\\n\\n')}\`,
    }],
  });
  return res.choices[0].message.content;
}`;

