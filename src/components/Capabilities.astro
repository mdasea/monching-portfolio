---
import { getCollection } from 'astro:content';

const services = await getCollection('services');
const skillsColl = await getCollection('skills');
const toolsColl = await getCollection('tools');

const skillData = skillsColl[0]?.data;

const capabilityGroups = [
  {
    title: 'Services',
    items: services.map(s => ({ name: s.data.title, desc: s.data.description }))
  },
];

// Add tool categories
if (toolsColl.length > 0) {
  toolsColl.forEach(t => {
    capabilityGroups.push({
      title: t.data.category,
      items: t.data.items.map(i => ({ name: i.name, desc: i.description || '' }))
    });
  });
}
---

<section class="section" id="capabilities">
  <div class="page">
    <div class="section-label">Skills & Tools</div>

    <!-- Skill groups with proficiency -->
    {skillData && (
      <div class="skill-bars">
        <div class="cap-grid" style="margin-bottom: 2.5rem;">
          {skillData.skillGroups.map(group => (
            <div class="cap-group">
              <div class="cap-group-title">{group.category}</div>
              {group.skills.map(skill => (
                <div class="skill-row">
                  <span class="skill-name">{skill.name}</span>
                  <div class="skill-bar-track">
                    <div class="skill-bar-fill" style="width: {skill.level}%; background: {skill.color};"></div>
                  </div>
                  <span class="skill-pct">{skill.level}%</span>
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Tool groups (comma-separated as before) -->
    <div class="cap-grid">
      {capabilityGroups.map(group => (
        <div class="cap-group">
          <div class="cap-group-title">{group.title}</div>
          <div class="cap-items">
            {group.items.map(item => (
              <span class="cap-item" title={item.desc}>{item.name}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    {skillData?.certifications && skillData.certifications.length > 0 && (
      <div style="margin-top: 2.5rem;">
        <div class="cap-group-title" style="margin-bottom: 0.75rem;">Certifications</div>
        <div class="cert-list">
          {skillData.certifications.map(cert => (
            <span class="cert-badge">
              {cert.link
                ? <a href={cert.link} target="_blank" rel="noopener noreferrer">{cert.name} ↗</a>
                : cert.name
              }
            </span>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style is:global>
  .skill-bars .cap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 2rem;
  }

  .skill-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }

  .skill-name {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-secondary);
    min-width: 100px;
    flex-shrink: 0;
  }

  .skill-bar-track {
    flex: 1;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .skill-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width var(--duration-normal) var(--ease);
  }

  .skill-pct {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-secondary);
    min-width: 32px;
    text-align: right;
  }

  .cert-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .cert-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-secondary);
    transition: all var(--duration-fast) var(--ease);
  }

  .cert-badge a {
    color: inherit;
    text-decoration: none;
  }

  .cert-badge:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .skill-bars .cap-grid {
      grid-template-columns: 1fr;
    }
    .skill-name {
      min-width: 80px;
      font-size: 0.75rem;
    }
  }
</style>
