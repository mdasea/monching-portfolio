---
<section class="section" id="connect">
  <div class="page">
    <div class="section-label">Connect</div>

    <p style="font-size: 1.1rem; margin-bottom: 1.5rem; color: var(--text-primary);">
      I'm currently available for full-time roles, contract work, and AI collaboration projects.
    </p>

    <!-- Availability badges -->
    <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 2rem;">
      <span class="avail-badge" style="border-color: var(--accent); color: var(--accent);">Full-time</span>
      <span class="avail-badge" style="border-color: var(--text-primary); color: var(--text-primary);">Contract</span>
      <span class="avail-badge" style="border-color: var(--text-secondary); color: var(--text-secondary);">AI Collabs</span>
    </div>

    <div class="connect-grid">
      <!-- Contact form -->
      <div class="connect-form-wrap">
        <div class="cap-group-title" style="margin-bottom: 0.75rem;">Send a message</div>
        <form id="contact-form" class="contact-form">
          <div class="form-group">
            <label for="form-name" class="form-label">Name</label>
            <input type="text" id="form-name" name="name" required class="form-input" placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="form-email" class="form-label">Email</label>
            <input type="email" id="form-email" name="email" required class="form-input" placeholder="you@example.com" />
          </div>
          <div class="form-group">
            <label for="form-message" class="form-label">Message</label>
            <textarea id="form-message" name="message" required class="form-input form-textarea" placeholder="Tell me about your project…" rows="4"></textarea>
          </div>
          <div id="form-status" class="form-status" hidden></div>
          <button type="submit" class="form-submit" id="form-submit-btn">Send message</button>
        </form>
      </div>

      <!-- Contact info -->
      <div class="connect-info">
        <div class="cap-group-title" style="margin-bottom: 0.75rem;">Reach out directly</div>
        <div class="contact-links-stack">
          <a href="mailto:desiertomonchingb@gmail.com" class="contact-link-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span>desiertomonchingb@gmail.com</span>
          </a>
          <a href="https://wa.me/639562206467" target="_blank" rel="noopener" class="contact-link-item">
