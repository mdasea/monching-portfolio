---
const workerUrl = 'https://monching-portfolio-chat.desiertomonchingb.workers.dev';
---

<div id="chatbot">
  <div id="chatbot-tooltip" class="chatbot-tooltip">
    <span class="chatbot-tooltip-text">Learn about Monching →</span>
    <div class="chatbot-tooltip-arrow"></div>
  </div>

  <button id="chatbot-trigger" class="chatbot-trigger" aria-label="Ask AI about Monching">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      <path d="M12 7 12.9 9.1 15 10 12.9 10.9 12 13 11.1 10.9 9 10 11.1 9.1z"/>
    </svg>
  </button>

  <div id="chatbot-panel" class="chatbot-panel chatbot-hidden" data-worker-url={workerUrl}>
    <div class="chatbot-header">
      <div class="chatbot-header-info">
        <div class="chatbot-header-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            <path d="M12 7 12.9 9.1 15 10 12.9 10.9 12 13 11.1 10.9 9 10 11.1 9.1z"/>
          </svg>
        </div>
        <div>
          <h3 class="chatbot-header-title">Ask Monching's AI</h3>
          <p class="chatbot-header-sub">Trained on portfolio data</p>
        </div>
      </div>
      <button id="chatbot-close" class="chatbot-close" aria-label="Close chat">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>

    <div class="chatbot-messages" id="chatbot-messages">
      <div class="chatbot-msg chatbot-bot">
        Welcome to Monching Desierto's portfolio. I'm his AI assistant — feel free to ask about his experience, skills, projects, or anything else.
      </div>
      <div class="chatbot-suggestions">
        <button class="chatbot-suggestion" data-question="What does Monching do?">What does Monching do?</button>
        <button class="chatbot-suggestion" data-question="What experience does Monching have?">Work experience</button>
        <button class="chatbot-suggestion" data-question="What technologies does Monching use?">Tech stack</button>
        <button class="chatbot-suggestion" data-question="What projects has Monching built?">Key projects</button>
        <button class="chatbot-suggestion" data-question="What certifications does Monching have?">Certifications</button>
        <button class="chatbot-suggestion" data-question="What AI tools does Monching use?">AI tools & vibe coding</button>
        <button class="chatbot-suggestion" data-question="How can I hire or contact Monching?">Hire / Contact</button>
      </div>
    </div>

    <div class="chatbot-inputbar">
      <input type="text" id="chatbot-input" class="chatbot-input" placeholder="Ask about Monching..." autocomplete="off" />
      <button id="chatbot-send" class="chatbot-send" aria-label="Send message">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4 20-7z"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  import { initChatbot } from '../scripts/chatbot';
  document.addEventListener('DOMContentLoaded', initChatbot);
</script>

<style is:global>
  .chatbot-trigger {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 9995;
    border: none;
    background: linear-gradient(135deg, #4f7df3, #6c5ce7);
    color: #fff;
    box-shadow: 0 4px 20px oklch(var(--color-primary) / 0.35);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    animation: chat-pulse-glow 3s ease-in-out infinite;
  }

  .chatbot-trigger.chatbot-raised {
    bottom: 7rem;
  }

  .chatbot-trigger:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 30px oklch(var(--color-primary) / 0.5);
  }

  .chatbot-trigger.chatbot-hidden {
    opacity: 0;
    transform: scale(0.8);
    pointer-events: none;
  }

  .chatbot-tooltip {
    position: fixed;
    bottom: 5.5rem;
    right: 2rem;
    z-index: 9998;
    cursor: pointer;
    opacity: 0;
    transform: translateY(10px);
    animation: chat-tooltip-in 3.5s ease-out 3s forwards;
    transition: bottom 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .chatbot-tooltip.chatbot-raised {
    bottom: 10.5rem;
  }

  .chatbot-tooltip-hidden {
    opacity: 0 !important;
    transform: translateY(10px) !important;
    pointer-events: none !important;
    animation: none !important;
  }

  .chatbot-tooltip-text {
    display: block;
    padding: 0.6rem 1rem;
    border-radius: 12px;
    font-size: 0.88rem;
    font-weight: 500;
    background: oklch(var(--color-base-100));
    border: 1px solid oklch(var(--color-primary) / 0.2);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    color: oklch(var(--color-base-content) / 0.9);
    white-space: nowrap;
    position: relative;
  }

  .chatbot-tooltip-arrow {
    position: absolute;
    bottom: -6px;
    right: 24px;
    width: 10px;
    height: 10px;
    background: oklch(var(--color-base-100));
    border-right: 1px solid oklch(var(--color-primary) / 0.2);
    border-bottom: 1px solid oklch(var(--color-primary) / 0.2);
    transform: rotate(45deg);
  }

  @keyframes chat-tooltip-in {
    0% { opacity: 0; transform: translateY(10px); }
    14% { opacity: 1; transform: translateY(0); }
    86% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(10px); }
  }

  @keyframes chat-pulse-glow {
    0%, 100% { box-shadow: 0 4px 20px oklch(var(--color-primary) / 0.3); }
    50% { box-shadow: 0 4px 30px oklch(var(--color-primary) / 0.5); }
  }

  .chatbot-panel {
    position: fixed;
    bottom: 7.5rem;
    right: 2rem;
    width: 380px;
    max-height: 560px;
    height: 60vh;
    display: flex;
    flex-direction: column;
    z-index: 9996;
    border-radius: 16px;
    border: 1px solid oklch(var(--color-base-content) / 0.1);
    background: oklch(var(--color-base-100));
    box-shadow: 0 16px 50px rgba(0,0,0,0.15);
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .chatbot-panel.chatbot-hidden {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    pointer-events: none;
  }

  .chatbot-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid oklch(var(--color-base-content) / 0.08);
    flex-shrink: 0;
  }

  .chatbot-header-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .chatbot-header-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #4f7df3, #6c5ce7);
    color: #fff;
    flex-shrink: 0;
  }

  .chatbot-header-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .chatbot-header-sub {
    font-size: 0.72rem;
    opacity: 0.5;
    margin: 0;
    font-family: var(--font-mono);
  }

  .chatbot-close {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 1px solid transparent;
    background: transparent;
    color: oklch(var(--color-base-content) / 0.4);
    transition: all 0.2s;
  }

  .chatbot-close:hover {
    border-color: oklch(var(--color-base-content) / 0.1);
    color: oklch(var(--color-base-content) / 0.8);
    background: oklch(var(--color-base-content) / 0.04);
  }

  .chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    scroll-behavior: smooth;
  }

  .chatbot-messages::-webkit-scrollbar {
    width: 4px;
  }

  .chatbot-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chatbot-messages::-webkit-scrollbar-thumb {
    background: oklch(var(--color-base-content) / 0.1);
    border-radius: 4px;
  }

  .chatbot-msg {
    max-width: 88%;
    padding: 0.65rem 1rem;
    border-radius: 12px;
    font-size: 0.88rem;
    line-height: 1.55;
    white-space: pre-wrap;
    word-wrap: break-word;
    animation: chat-fade-in 0.25s ease-out;
  }

  .chatbot-user {
    align-self: flex-end;
    background: linear-gradient(135deg, #4f7df3, #6c5ce7);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  .chatbot-bot {
    align-self: flex-start;
    background: oklch(var(--color-base-200));
    border: 1px solid oklch(var(--color-base-content) / 0.06);
    border-bottom-left-radius: 4px;
    color: oklch(var(--color-base-content) / 0.85);
  }

  .chatbot-bot p {
    margin: 0 0 0.5rem;
  }

  .chatbot-bot p:last-child {
    margin-bottom: 0;
  }

  .chatbot-bot strong {
    font-weight: 700;
    color: oklch(var(--color-base-content));
  }

  .chatbot-bot em {
    font-style: italic;
  }

  .chatbot-bot ul, .chatbot-bot ol {
    margin: 0.25rem 0;
    padding-left: 1.25rem;
  }

  .chatbot-bot li {
    margin-bottom: 0.2rem;
  }

  .chatbot-bot code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    background: oklch(var(--color-base-content) / 0.06);
    color: oklch(var(--color-primary));
  }

  .chatbot-bot pre {
    margin: 0.5rem 0;
    border-radius: 8px;
    overflow-x: auto;
  }

  .chatbot-bot pre code {
    display: block;
    padding: 0.75rem;
    font-size: 0.8rem;
    line-height: 1.5;
    background: oklch(var(--color-base-300));
    white-space: pre;
  }

  .chatbot-bot a {
    color: oklch(var(--color-primary));
    text-decoration: underline;
  }

  .chatbot-bot h3, .chatbot-bot h4 {
    font-weight: 700;
    margin: 0.75rem 0 0.25rem;
  }

  .chatbot-bot h3 { font-size: 0.95rem; }
  .chatbot-bot h4 { font-size: 0.9rem; }

  .chatbot-bot hr {
    border: none;
    border-top: 1px solid oklch(var(--color-base-content) / 0.1);
    margin: 0.5rem 0;
  }

  @keyframes chat-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .chatbot-typing {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0.85rem 1.25rem;
  }

  .dot-pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: oklch(var(--color-base-content) / 0.3);
    animation: chat-dot-pulse 1.4s ease-in-out infinite;
  }

  .dot-pulse:nth-child(2) { animation-delay: 0.2s; }
  .dot-pulse:nth-child(3) { animation-delay: 0.4s; }

  @keyframes chat-dot-pulse {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
    40% { transform: scale(1); opacity: 0.8; }
  }

  .chatbot-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .chatbot-suggestion {
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid oklch(var(--color-primary) / 0.15);
    background: oklch(var(--color-primary) / 0.04);
    color: oklch(var(--color-primary));
    transition: all 0.2s;
    font-family: var(--font-mono);
    white-space: nowrap;
  }

  .chatbot-suggestion:hover {
    background: oklch(var(--color-primary) / 0.1);
    border-color: oklch(var(--color-primary) / 0.3);
    transform: translateY(-1px);
  }

  .chatbot-inputbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid oklch(var(--color-base-content) / 0.08);
    flex-shrink: 0;
    background: oklch(var(--color-base-200) / 0.3);
  }

  .chatbot-input {
    flex: 1;
    border: 1px solid oklch(var(--color-base-content) / 0.1);
    border-radius: 10px;
    padding: 0.6rem 0.85rem;
    font-size: 0.88rem;
    font-family: var(--font-sans);
    background: oklch(var(--color-base-100));
    color: oklch(var(--color-base-content));
    outline: none;
    transition: border-color 0.2s;
  }

  .chatbot-input:focus {
    border-color: oklch(var(--color-primary) / 0.4);
    box-shadow: 0 0 0 3px oklch(var(--color-primary) / 0.06);
  }

  .chatbot-input::placeholder {
    color: oklch(var(--color-base-content) / 0.3);
  }

  .chatbot-send {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    background: linear-gradient(135deg, #4f7df3, #6c5ce7);
    color: #fff;
    flex-shrink: 0;
    transition: all 0.2s;
  }

  .chatbot-send:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 12px oklch(var(--color-primary) / 0.3);
  }

  .chatbot-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  @media (max-width: 768px) {
    .chatbot-panel {
      right: 0.75rem;
      left: 0.75rem;
      width: auto;
      bottom: 6rem;
      max-height: 65vh;
    }

    .chatbot-trigger {
      right: 0.75rem;
      bottom: 2rem;
      width: 40px;
      height: 40px;
    }

    .chatbot-trigger.chatbot-raised {
      bottom: 6rem;
    }

    .chatbot-tooltip {
      right: 0.75rem;
      bottom: 5rem;
    }

    .chatbot-tooltip.chatbot-raised {
      bottom: 9rem;
    }

    .chatbot-msg {
      max-width: 92%;
    }
  }
</style>
