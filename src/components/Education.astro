---
<section class="section" id="education">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title">Education & <span class="gradient-text">Awards</span></h2>
      <p class="section-subtitle">Academic background and achievements</p>
    </div>

    <div class="edu-grid">
      <div class="edu-card card-custom reveal">
        <div class="edu-logo-ring">
          <img src="/mapua-logo.png" alt="Mapúa University" class="edu-logo" />
        </div>
        <div class="edu-body">
          <h3>
            <a href="https://www.mapua.edu.ph/" target="_blank" rel="noopener noreferrer" class="edu-link">
              Mapúa University
            </a>
          </h3>
          <p class="edu-degree">Master of Science in Computer Science</p>
          <span class="edu-year">Present</span>
        </div>
      </div>

      <div class="edu-card card-custom reveal reveal-delay-1">
        <div class="edu-logo-ring">
          <img src="/cit-logo.png" alt="Cebu Institute of Technology" class="edu-logo" />
        </div>
        <div class="edu-body">
          <h3>
            <a href="https://cit.edu/" target="_blank" rel="noopener noreferrer" class="edu-link">
              Cebu Institute of Technology
            </a>
          </h3>
          <p class="edu-degree">Bachelor of Science in Computer Science</p>
          <p class="edu-honors">Cum Laude &middot; DOST Scholar</p>
          <span class="edu-year">2018 — 2022</span>
        </div>
      </div>
    </div>

    <div class="awards-grid reveal reveal-delay-2">
      <div class="award-card">
        <div class="award-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div class="award-body">
          <span class="award-rank">Top 10</span>
          <p class="award-label">National Rank<br/>TOPCIT Exam</p>
        </div>
      </div>
      <div class="award-card">
        <div class="award-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div class="award-body">
          <span class="award-rank">1st</span>
          <p class="award-label">Runner-Up, Java<br/>IT Olympics</p>
        </div>
      </div>
      <div class="award-card">
        <div class="award-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div class="award-body">
          <span class="award-rank">Champion</span>
          <p class="award-label">Region VII Coding<br/>Challenge</p>
        </div>
      </div>
      <div class="award-card">
        <div class="award-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div class="award-body">
          <span class="award-rank">Cum Laude</span>
          <p class="award-label">Graduation<br/>Honors</p>
        </div>
      </div>
      <div class="award-card">
        <div class="award-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div class="award-body">
          <span class="award-rank">1st</span>
          <p class="award-label">AI Hackathon<br/>Winner (Global)</p>
        </div>
      </div>
      <div class="award-card">
        <div class="award-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div class="award-body">
          <span class="award-rank">Passed</span>
          <p class="award-label">PhilNITS FE<br/>Examination</p>
        </div>
      </div>
      <div class="award-card">
        <div class="award-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <div class="award-body">
          <span class="award-rank">Scholar</span>
          <p class="award-label">DOST<br/>Scholarship</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .edu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .edu-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: oklch(var(--color-base-200) / 0.3);
    border: 1px solid oklch(var(--color-base-content) / 0.08);
    align-items: center;
    transition: all 0.3s;
  }

  .edu-card:hover {
    border-color: oklch(var(--color-primary) / 0.2);
    transform: translateY(-3px);
    box-shadow: 0 8px 25px oklch(var(--color-primary) / 0.06);
  }

  .edu-logo-ring {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid oklch(var(--color-base-content) / 0.08);
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
  }

  .edu-card:hover .edu-logo-ring {
    border-color: oklch(var(--color-primary));
    box-shadow: 0 0 20px oklch(var(--color-primary) / 0.12);
  }

  .edu-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .edu-body h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }

  .edu-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .edu-link::after {
    content: ' \2197';
    font-size: 0.75rem;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .edu-link:hover {
    color: oklch(var(--color-primary));
  }

  .edu-link:hover::after {
    opacity: 1;
  }

  .edu-degree {
    font-size: 0.85rem;
    opacity: 0.6;
  }

  .edu-honors {
    font-size: 0.85rem;
    color: oklch(var(--color-primary));
    font-weight: 500;
    margin-top: 0.1rem;
  }

  .edu-year {
    display: inline-block;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: oklch(var(--color-primary) / 0.06);
    color: oklch(var(--color-primary));
    border: 1px solid oklch(var(--color-primary) / 0.1);
    margin-top: 0.4rem;
  }

  .awards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
    gap: 0.85rem;
  }

  .award-card {
    background: oklch(var(--color-base-200) / 0.3);
    border: 1px solid oklch(var(--color-base-content) / 0.06);
    border-radius: 12px;
    padding: 1.2rem;
    text-align: center;
    transition: all 0.3s;
  }

  .award-card:hover {
    border-color: oklch(var(--color-primary) / 0.2);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px oklch(var(--color-primary) / 0.05);
  }

  .award-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 0.5rem;
    color: oklch(var(--color-primary));
    opacity: 0.6;
  }

  .award-rank {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, #4f7df3, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.25rem;
  }

  .award-label {
    font-size: 0.78rem;
    opacity: 0.55;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .edu-grid { grid-template-columns: 1fr; }
    .awards-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
