---
const navItems = [
  { label: 'Services', href: '/#services' },
  { label: 'Experience', href: '/#experience' },
  { label: 'Projects', href: '/#projects' },
  { label: 'Testimonials', href: '/#testimonials' },
  { label: 'Skills', href: '/#skills' },
  { label: 'Contact', href: '/#contact' },
];
---

<nav class="navbar-custom" id="navbar">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">MD</a>

    <ul class="nav-links" id="navLinks">
      {navItems.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
      <li class="nav-dropdown-wrap">
        <button class="nav-dropdown-trigger" id="tkTrigger" aria-haspopup="true" aria-expanded="false">
          Toolkit
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="dropdown-chevron"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <ul class="nav-dropdown" id="tkDropdown">
          <li><a href="/toolkit/development">Development</a></li>
          <li><a href="/toolkit/ai-automation">AI Automation</a></li>
          <li><a href="/toolkit/lovable">Lovable.dev</a></li>
        </ul>
      </li>
    </ul>

    <div class="nav-actions">
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2"/><path d="M12 21v2"/><path d="M4.22 4.22l1.42 1.42"/><path d="M18.36 18.36l1.42 1.42"/><path d="M1 12h2"/><path d="M21 12h2"/><path d="M4.22 19.78l1.42-1.42"/><path d="M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('navbar');
  const navLinks = document.getElementById('navLinks');
  const toggle = document.getElementById('navToggle');
  const themeBtn = document.getElementById('themeToggle');
  const tkTrigger = document.getElementById('tkTrigger');
  const tkDropdown = document.getElementById('tkDropdown');
  let lastScroll = 0;

  toggle?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
    toggle?.classList.toggle('active');
  });

  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
      navLinks?.classList.remove('open');
      toggle?.classList.remove('active');
      tkDropdown?.classList.remove('open');
      tkTrigger?.setAttribute('aria-expanded', 'false');
    });
  });

  // Toolkit dropdown toggle (for mobile)
  tkTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = tkDropdown?.classList.toggle('open');
    tkTrigger?.setAttribute('aria-expanded', String(!!isOpen));
  });

  // Close dropdown on click outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.nav-dropdown-wrap')) {
      tkDropdown?.classList.remove('open');
      tkTrigger?.setAttribute('aria-expanded', 'false');
    }
  });

  // Highlight Toolkit nav item when on /toolkit/ pages
  const tkWrap = document.querySelector('.nav-dropdown-wrap');
  if (tkWrap && window.location.pathname.startsWith('/toolkit/')) {
    const tkLink = tkWrap.querySelector('.nav-dropdown-trigger');
    if (tkLink) tkLink.classList.add('active');
    const subLinks = tkWrap.querySelectorAll('.nav-dropdown a');
    subLinks.forEach(a => {
      if (a.getAttribute('href') === window.location.pathname) {
        a.classList.add('active');
      }
    });
  }

  themeBtn?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    themeBtn.style.transform = 'rotate(360deg)';
    setTimeout(() => { themeBtn.style.transform = ''; }, 300);
  });

  // Active section highlight — only on pages with sections
  const sections = document.querySelectorAll('section[id]');
  const sectionLinks = document.querySelectorAll('.nav-links a');

  if (sections.length > 0) {
    const sectionObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          sectionLinks.forEach(link => {
            link.classList.toggle('active', link.getAttribute('href') === `/#${id}`);
          });
        }
      });
    }, { threshold: 0.3, rootMargin: '-80px 0px 0px 0px' });

    sections.forEach(s => sectionObserver.observe(s));
  }

  // Scroll hide/show nav
  window.addEventListener('scroll', () => {
    const current = window.scrollY;
    if (current > 80) {
      if (current > lastScroll) {
        nav?.classList.add('nav-hidden');
      } else {
        nav?.classList.remove('nav-hidden');
      }
    } else {
      nav?.classList.remove('nav-hidden');
    }
    lastScroll = current;
  }, { passive: true });
</script>

<style is:global>
  .navbar-custom {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: color-mix(in srgb, oklch(var(--color-base-100)) 85%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid oklch(var(--color-base-content) / 0.08);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-hidden {
    transform: translateY(-100%);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .nav-logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: oklch(var(--color-primary)) !important;
    letter-spacing: -0.05em;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-links a {
    color: oklch(var(--color-base-content) / 0.55);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
    position: relative;
    text-decoration: none;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: oklch(var(--color-primary));
    transition: width 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: oklch(var(--color-base-content));
  }

  .nav-links a:hover::after,
  .nav-links a.active::after {
    width: 100%;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    border: 1px solid oklch(var(--color-base-content) / 0.12);
    background: transparent;
    cursor: pointer;
    color: oklch(var(--color-base-content) / 0.65);
    transition: all 0.3s;
  }

  .theme-toggle:hover {
    border-color: oklch(var(--color-primary));
    color: oklch(var(--color-primary));
    background: oklch(var(--color-primary) / 0.06);
  }

  html[data-theme="light"] .theme-toggle .icon-moon { display: none; }
  html[data-theme="dark"] .theme-toggle .icon-sun { display: none; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    z-index: 1001;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: oklch(var(--color-base-content));
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle.active span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .nav-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Toolkit dropdown */
  .nav-dropdown-wrap {
    position: relative;
  }

  .nav-dropdown-trigger {
    background: none;
    border: none;
    color: oklch(var(--color-base-content) / 0.55);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0;
    font-family: inherit;
    transition: color 0.2s;
  }

  .nav-dropdown-trigger:hover,
  .nav-dropdown-trigger.active {
    color: oklch(var(--color-base-content));
  }

  .dropdown-chevron {
    transition: transform 0.2s;
  }

  .nav-dropdown-wrap:hover .dropdown-chevron,
  .nav-dropdown.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    min-width: 170px;
    background: oklch(var(--color-base-100));
    border: 1px solid oklch(var(--color-base-content) / 0.1);
    border-radius: 10px;
    box-shadow: 0 8px 25px rgb(0 0 0 / 0.1);
    opacity: 0;
    pointer-events: none;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1002;
  }

  .nav-dropdown-wrap:hover .nav-dropdown,
  .nav-dropdown.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(8px);
  }

  .nav-dropdown a {
    display: block;
    padding: 0.5rem 1.25rem;
    font-size: 0.88rem;
    white-space: nowrap;
    color: oklch(var(--color-base-content) / 0.6) !important;
  }

  .nav-dropdown a::after { display: none; }

  .nav-dropdown a:hover,
  .nav-dropdown a.active {
    color: oklch(var(--color-base-content)) !important;
    background: oklch(var(--color-base-content) / 0.04);
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: color-mix(in srgb, oklch(var(--color-base-100)) 98%, transparent);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      padding: 2rem;
      opacity: 0;
      pointer-events: none;
      transform: scale(0.95);
      transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-links.open {
      opacity: 1;
      pointer-events: auto;
      transform: scale(1);
    }

    .nav-links a {
      font-size: 1.2rem;
      font-weight: 600;
    }

    /* Mobile dropdown — inline, no absolute positioning */
    .nav-dropdown {
      position: static;
      transform: none;
      box-shadow: none;
      background: transparent;
      border: none;
      padding: 0 0 0 1rem;
      max-height: 0;
      overflow: hidden;
      opacity: 1;
      pointer-events: none;
      transition: max-height 0.3s ease, opacity 0.2s;
    }

    .nav-dropdown-wrap:hover .nav-dropdown,
    .nav-dropdown.open {
      max-height: 200px;
      opacity: 1;
      pointer-events: auto;
      transform: none;
    }

    .nav-dropdown a {
      font-size: 1rem;
      padding: 0.5rem 0;
    }
  }
</style>
