      <span class="stack-badge"><span class="stack-dot" style="background:#6db33f"></span>Spring</span>
      <span class="stack-badge"><span class="stack-dot" style="background:#61dbfb"></span>React</span>
      <span class="stack-badge"><span class="stack-dot" style="background:#42b883"></span>Vue</span>
      <span class="stack-badge"><span class="stack-dot" style="background:#8b5cf6"></span>AI</span>
      <span class="stack-badge"><span class="stack-dot" style="background:#ef4444"></span>TOPCIT Top 10</span>
      <span class="stack-badge"><span class="stack-dot" style="background:#2563eb"></span>PhilNITS FE</span>
    </div>

    <div class="hero-actions">
      <a href="#contact" class="btn-hero btn-hero-primary">
        Let's Work Together
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="https://canva.link/a2vi9gtr5yd0u7x" target="_blank" class="btn-hero btn-hero-outline">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        View Resume
      </a>
    </div>

    <div class="hero-socials">
      <a href="mailto:desiertomonchingb@gmail.com" target="_blank" title="Email" aria-label="Email" class="social-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span>Email</span>
      </a>
      <a href="https://www.linkedin.com/in/monchingdesierto" target="_blank" title="LinkedIn" aria-label="LinkedIn" class="social-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        <span>LinkedIn</span>
      </a>
      <a href="https://github.com/mdasea" target="_blank" title="GitHub" aria-label="GitHub" class="social-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span>GitHub</span>
      </a>
      <a href="https://v2.onlinejobs.ph/jobseekers/info/4504838" target="_blank" title="OnlineJobs.ph" aria-label="OnlineJobs.ph" class="social-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <span>OnlineJobs</span>
      </a>
    </div>
  </div>

  <div class="hero-scroll">
    <span>Scroll</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
  </div>
</section>

<script>
  const words = [
    'Full Stack Software Developer',
    'Java EE / Spring Specialist',
    'React & Vue Frontend Developer',
    'AI-Powered Developer',
    'Performance Optimizer',
    'TOPCIT National Ranker',
    'PhilNITS FE Passer',
  ];
  let wordIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const el = document.getElementById('typewriter');

  function type() {
    if (!el) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = words[0];
      return;
    }

    const current = words[wordIndex];
    if (isDeleting) {
      el.textContent = current.substring(0, charIndex - 1);
      charIndex--;
    } else {
      el.textContent = current.substring(0, charIndex + 1);
      charIndex++;
    }
    if (!isDeleting && charIndex === current.length) {
      setTimeout(() => { isDeleting = true; type(); }, 2500);
      return;
    }
    if (isDeleting && charIndex === 0) {
      isDeleting = false;
      wordIndex = (wordIndex + 1) % words.length;
      setTimeout(type, 500);
      return;
    }
    setTimeout(type, isDeleting ? 30 : 60);
  }
  type();
</script>

<style is:global>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 40%, oklch(var(--color-primary) / 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 60%, oklch(0.55 0.22 300 / 0.05) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 50% 10%, oklch(0.65 0.2 160 / 0.03) 0%, transparent 50%);
    animation: heroGradient 12s ease-in-out infinite alternate;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(oklch(var(--color-primary) / 0.05) 1px, transparent 1px),
      linear-gradient(90deg, oklch(var(--color-primary) / 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.5;
  }

  .hero-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    opacity: 0.3;
    animation: particleFloat 20s infinite;
  }

  .p1 { top: 20%; left: 10%; animation-delay: 0s; background: #4f7df3; }
  .p2 { top: 60%; left: 85%; animation-delay: -5s; background: #8b5cf6; }
  .p3 { top: 80%; left: 20%; animation-delay: -10s; background: #10b981; }
  .p4 { top: 30%; left: 75%; animation-delay: -15s; background: #06b6d4; }
  .p5 { top: 70%; left: 50%; width: 6px; height: 6px; animation-delay: -7s; background: #f59e0b; }

  .hero-content {
    display: block;
    text-align: center;
    position: relative;
    z-index: 1;
    animation: fadeIn 1s ease-out;
    padding-top: 5rem;
    padding-bottom: 0;
    max-width: var(--max-width);
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    color: oklch(var(--color-success));
    background: oklch(var(--color-success) / 0.08);
    border: 1px solid oklch(var(--color-success) / 0.15);
    margin-bottom: 2rem;
    backdrop-filter: blur(4px);
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .hero-avatar-ring {
    display: block;
    margin: 0 auto 1.5rem;
    position: relative;
    padding: 5px;
    border-radius: 50%;
    background: linear-gradient(135deg, #4f7df3, #8b5cf6, #10b981, #4f7df3);
    background-size: 300% 300%;
    animation: avatar-ring 4s ease-in-out infinite;
    width: fit-content;
  }

  @keyframes avatar-ring {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid oklch(var(--color-base-100));
    display: block;
    max-width: none;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .hero-type-wrapper {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
    min-height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    opacity: 0.8;
  }

  .hero-type-prompt {
    color: oklch(var(--color-success));
    font-weight: 700;
  }

  .hero-type-cursor {
    color: oklch(var(--color-primary));
    animation: blink 1s step-end infinite;
    font-weight: 100;
  }

  .hero-desc {
    max-width: 600px;
    margin: 0 auto 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
    opacity: 0.6;
    text-wrap: balance;
  }

  .hero-desc-tags {
    display: block;
    margin-top: 0.15rem;
    font-size: 0.8rem;
    opacity: 0.5;
  }

  .hero-stack-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .stack-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 500;
    background: oklch(var(--color-base-200) / 0.6);
    border: 1px solid oklch(var(--color-base-content) / 0.1);
    color: oklch(var(--color-base-content) / 0.7);
    transition: all 0.2s;
  }

  .stack-badge:hover {
    border-color: oklch(var(--color-primary) / 0.3);
    color: oklch(var(--color-base-content));
    transform: translateY(-2px);
  }

  .stack-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.75rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
    border: none;
    text-decoration: none;
  }

  .btn-hero-primary {
    background: linear-gradient(135deg, #4f7df3, #6c5ce7);
    color: #fff;
    box-shadow: 0 4px 15px oklch(var(--color-primary) / 0.3);
  }

  .btn-hero-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px oklch(var(--color-primary) / 0.4);
    color: #fff;
  }

  .btn-hero-outline {
    background: transparent;
    color: oklch(var(--color-base-content));
    border: 1px solid oklch(var(--color-base-content) / 0.15);
  }

  .btn-hero-outline:hover {
    border-color: oklch(var(--color-primary));
    color: oklch(var(--color-primary));
    background: oklch(var(--color-primary) / 0.04);
    transform: translateY(-2px);
  }

  .hero-socials {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    border: 1px solid oklch(var(--color-base-content) / 0.1);
    color: oklch(var(--color-base-content) / 0.55);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s;
  }

  .social-link:hover {
    color: oklch(var(--color-primary));
    border-color: oklch(var(--color-primary) / 0.35);
    background: oklch(var(--color-primary) / 0.05);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px oklch(var(--color-primary) / 0.1);
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    opacity: 0.5;
    animation: scrollFloat 2.5s ease-in-out infinite;
    z-index: 1;
  }

  .hero-scroll svg {
    width: 16px;
    height: 16px;
    animation: scrollBounce 1.8s ease-in-out infinite;
  }

  @keyframes scrollFloat {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-6px); }
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(4px); opacity: 0.4; }
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.5rem; }
    .hero-avatar { width: 64px; height: 64px; }
    .hero-avatar-ring { padding: 3px; }
    .hero-type-wrapper { font-size: 0.9rem; flex-wrap: wrap; }
    .hero-stack-badges { gap: 0.35rem; }
    .stack-badge { font-size: 0.72rem; padding: 0.25rem 0.6rem; }
    .social-link span { display: none; }
  }
</style>
