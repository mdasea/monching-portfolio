</section>

<style is:global>
  .hero-inner {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
  }

  .hero-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--border);
    margin-top: 0.25rem;
    transition: border-color var(--duration-fast) var(--ease);
  }

  .hero-avatar:hover {
    border-color: var(--accent);
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-badge-row {
    margin-bottom: 1rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-secondary);
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-tagline {
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .hero-tagline strong {
    color: var(--accent);
    font-weight: 700;
  }

  .hero-subtagline {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
    max-width: 540px;
    line-height: 1.6;
  }

  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.25rem;
  }

  .stack-chip {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-secondary);
    transition: all var(--duration-fast) var(--ease);
  }

  .stack-chip:hover {
    border-color: var(--chip-color);
    color: var(--chip-color);
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }

  .hero-cta .primary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--bg);
    background: var(--text-primary);
    border-radius: 6px;
    transition: all var(--duration-fast) var(--ease);
  }

  .hero-cta .primary-link:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .hero-cta .resume-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: all var(--duration-fast) var(--ease);
  }

  .hero-cta .resume-link:hover {
    border-color: var(--text-primary);
    color: var(--text-primary);
  }

  .hero-socials {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .social-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease);
  }

  .social-icon-link:hover {
    color: var(--text-primary);
    border-color: var(--text-secondary);
    transform: translateY(-2px);
  }

  .hero-scroll {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-top: 2.5rem;
    opacity: 0.5;
    animation: bounce-scroll 2s ease-in-out infinite;
  }

  @keyframes bounce-scroll {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(4px); opacity: 0.8; }
  }

  @media (max-width: 640px) {
    .hero-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .hero-cta {
      justify-content: center;
    }
    .hero-stack {
      justify-content: center;
    }
    .hero-socials {
      justify-content: center;
    }
    .hero-avatar {
      width: 72px;
      height: 72px;
    }
    .hero-subtagline {
      max-width: 100%;
    }
    .hero-scroll {
      display: none;
    }
  }
</style>
