---
import { getCollection } from 'astro:content';

const [eduData] = await getCollection('education');
const [featData] = await getCollection('featured');

const { schools, awards } = eduData.data;
const { items: featuredItems } = featData.data;
---

<section class="section" id="background">
  <div class="page">
    <div class="section-label">Education & Recognition</div>

    <!-- Schools -->
    <div class="edu-grid">
      {schools.map(school => (
        <div class="edu-card">
          {school.logoSrc && (
            <img src={school.logoSrc} alt={`${school.name} logo`} class="edu-logo" width="24" height="24" />
          )}
          <div class="edu-body">
            <div class="edu-name">{school.link ? <a href={school.link} target="_blank" rel="noopener noreferrer">{school.name} ↗</a> : school.name}</div>
            <div class="edu-degree">{school.degree}</div>
            <div class="edu-meta">
              <span>{school.year}</span>
              {school.honors && <span class="edu-honors">{school.honors}</span>}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Awards -->
    {awards.length > 0 && (
      <div style="margin: 2rem 0;">
        <div class="cap-group-title" style="margin-bottom: 0.75rem;">Awards</div>
        <div class="award-list">
          {awards.map(award => (
            <span class="award-chip">
              <span class="award-title">{award.title}</span>
              <span class="award-desc">{award.description}</span>
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Featured / Press Mentions -->
    {featuredItems.length > 0 && (
      <div style="margin: 2.5rem 0 0;">
        <div class="cap-group-title" style="margin-bottom: 0.75rem;">As Featured In</div>
        <div class="feat-list">
          {featuredItems.map(item => (
            <a href={item.href} target="_blank" rel="noopener noreferrer" class="feat-item">
              {item.image && (
                <img src={item.image} alt={item.imageAlt || ''} class="feat-thumb" width="60" height="60" loading="lazy" />
              )}
              <div class="feat-body">
                <div class="feat-source">{item.sourceLabel}</div>
                <div class="feat-title">{item.title}</div>
                <div class="feat-desc">{item.description}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style is:global>
  .edu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .edu-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .edu-logo {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    margin-top: 0.15rem;
    object-fit: contain;
  }

  .edu-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .edu-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-primary);
  }

  .edu-name a {
    color: inherit;
    text-decoration: none;
  }

  .edu-name a:hover {
    color: var(--accent);
  }

  .edu-degree {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .edu-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.78rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .edu-honors {
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .award-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .award-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-secondary);
  }

  .award-title {
    color: var(--accent);
    font-weight: 600;
  }

  .award-desc {
    color: var(--text-secondary);
  }

  .feat-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feat-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease);
  }

  .feat-item:hover {
    border-color: var(--text-secondary);
  }

  .feat-thumb {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .feat-body {
    flex: 1;
    min-width: 0;
  }

  .feat-source {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    margin-bottom: 0.15rem;
  }

  .feat-title {
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--text-primary);
    margin-bottom: 0.15rem;
  }

  .feat-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .edu-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
