</section>

<style is:global>
  .contact-card {
    max-width: 800px;
    margin: 0 auto;
    background: oklch(var(--color-base-200) / 0.4);
    border: 1px solid oklch(var(--color-base-content) / 0.08);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s;
  }

  .contact-card:hover {
    border-color: oklch(var(--color-primary) / 0.15);
    box-shadow: 0 8px 30px oklch(var(--color-primary) / 0.05);
  }

  .contact-card-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 2.5rem;
  }

  .contact-heading {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .contact-text {
    font-size: 0.92rem;
    opacity: 0.6;
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .contact-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.5rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.92rem;
    background: linear-gradient(135deg, #4f7df3, #6c5ce7);
    color: #fff;
    box-shadow: 0 4px 15px oklch(var(--color-primary) / 0.3);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .contact-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px oklch(var(--color-primary) / 0.4);
    color: #fff;
  }

  .contact-availability {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .avail-badge {
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid;
  }

  .avail-fulltime {
    background: oklch(var(--color-success) / 0.06);
    border-color: oklch(var(--color-success) / 0.15);
    color: oklch(var(--color-success));
  }
  .avail-contract {
    background: oklch(var(--color-primary) / 0.06);
    border-color: oklch(var(--color-primary) / 0.15);
    color: oklch(var(--color-primary));
  }
  .avail-ai {
    background: oklch(var(--color-secondary) / 0.06);
    border-color: oklch(var(--color-secondary) / 0.15);
    color: oklch(var(--color-secondary));
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
    border-radius: 10px;
    border: 1px solid oklch(var(--color-base-content) / 0.06);
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
    background: oklch(var(--color-base-100) / 0.5);
  }

  .contact-item:hover {
    border-color: oklch(var(--color-primary));
    background: oklch(var(--color-primary) / 0.04);
    transform: translateX(4px);
    color: inherit;
  }

  .contact-item-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: oklch(var(--color-primary) / 0.06);
    color: oklch(var(--color-primary));
    flex-shrink: 0;
  }

  .contact-item:hover .contact-item-icon {
    background: oklch(var(--color-primary) / 0.12);
  }

  .contact-item-body {
    flex: 1;
    min-width: 0;
  }

  .contact-item-name {
    display: block;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .contact-item-meta {
    display: block;
    font-size: 0.78rem;
    opacity: 0.45;
    font-family: var(--font-mono);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-arrow {
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.25s;
    color: oklch(var(--color-primary));
  }

  .contact-item:hover .contact-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .contact-card-inner { grid-template-columns: 1fr; gap: 2rem; padding: 1.75rem; }
  }

  @media (max-width: 768px) {
    .contact-card-inner { grid-template-columns: 1fr; gap: 2rem; padding: 1.75rem; }
  }
</style>
