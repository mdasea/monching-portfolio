---
import { getCollection } from 'astro:content';
import { icons } from '../lib/icons';

const iconMap: Record<string, string> = {
  bot: icons.bot,
  globe: icons.globe,
  lightbulb: icons.lightbulb,
  search: icons.search,
  shoppingCart: icons.shoppingCart,
  smartphone: icons.smartphone,
  drone: icons.drone,
  waves: icons.waves,
  flask: icons.flask,
  graduation: icons.graduation,
};

const projects = await getCollection('projects');
---

<section class="section" id="projects">
  <div class="page">
    <div class="section-label">Selected Work</div>
    <div class="entry-list">
      {projects.map(({ data }) => (
        <div class="entry">
          <div class="entry-header">
            <div class="entry-title-group">
              {data.icon && iconMap[data.icon] ? (
                <span class="entry-icon" style={`color: ${data.accent}`} set:html={iconMap[data.icon]}></span>
              ) : data.link ? (
                <span class="entry-icon" style="color: var(--text-secondary); opacity: 0.4;" set:html={icons.link}></span>
              ) : null}
              <h3 class="entry-title">
                {data.link
                  ? <a href={data.link} target="_blank" rel="noopener noreferrer">{data.title} ↗</a>
                  : data.title
                }
              </h3>
            </div>
          </div>
          <p class="entry-desc">{data.description}</p>
          <div class="entry-tags">
            {data.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .entry-title-group {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .entry-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
  }

  .entry-icon svg {
    width: 18px;
    height: 18px;
  }
</style>
