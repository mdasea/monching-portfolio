---
import { getCollection } from 'astro:content';

const [wfData] = await getCollection('workflow');
const steps = wfData.data.steps;
---

<section class="section" id="workflow">
  <div class="page">
    <div class="section-label">How I Work</div>
    <div class="wf-grid">
      {steps.map(step => (
        <div class="wf-step">
          <div class="wf-num">{step.num}</div>
          <div class="wf-body">
            <div class="wf-title">{step.title}</div>
            <p class="wf-desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .wf-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .wf-step {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .wf-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.5;
    line-height: 1;
    flex-shrink: 0;
    min-width: 2rem;
  }

  .wf-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .wf-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .wf-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .wf-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
