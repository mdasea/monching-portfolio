---
interface FeaturedItem {
  href: string;
  image?: string;
  imageAlt?: string;
  sourceLabel: string;
  title: string;
  description: string;
}

const items: FeaturedItem[] = [
  {
    href: 'https://www.linkedin.com/feed/update/urn:li:activity:7350662540168753154/',
    image: '/linkedin-featured-1.jpg',
    imageAlt: 'LinkedIn Post - Hackathon Win',
    sourceLabel: 'Monching Desierto \u00B7 LinkedIn',
    title: 'Hackathon Champion \u2014 #TeamPathFinders',
    description: 'Won an international hackathon with a global team. Announcing the incredible achievement celebrating teamwork, innovation, and hard work that made it all possible.',
  },
  {
    href: 'https://web.facebook.com/cstaromana/posts/international-collaboration-achieved-this-morning-bscs-students-of-cit-universit/10221743783316167/',
    image: '/cit-featured-5.jpg',
    imageAlt: 'International Research Collaboration - CIT x STUST',
    sourceLabel: 'Cherry Lyn Sta Romana \u00B7 Facebook',
    title: 'International Research Collaboration \u2014 CIT x STUST',
    description: 'BSCS students of CIT University successfully presented six (6) research projects created in collaboration with the Southern Taiwan University of Science and Technology \u2014 including Monching\'s research on monocular image object-depth estimation.',
  },
  {
    href: 'https://web.facebook.com/CITUniversity/posts/5408272749203035',
    image: '/cit-featured.jpg',
    imageAlt: 'CIT University Facebook Post - Academic Excellence',
    sourceLabel: 'CIT University \u00B7 Facebook',
    title: '#CITTopsAgain',
    description: 'Congratulations to the top-performing students recognized by Cebu Institute of Technology - University for academic excellence and outstanding achievements.',
  },
  {
    href: 'https://web.facebook.com/CITUniversity/posts/cittopsagainour-very-own-students-from-the-computer-science-department-reigned-c/3042615402435460/',
    image: '/cit-featured-2.jpg',
    imageAlt: 'CIT University Facebook Post - Coding Challenge',
    sourceLabel: 'CIT University \u00B7 Facebook',
    title: '#CITTopsAgain \u2014 Coding Challenge Champions',
    description: 'Our very own students from the Computer Science Department reigned Champion in the Central Visayas Coding Challenge held last February 22, 2020, in cooperation with the Philippine.',
  },
  {
    href: 'https://web.facebook.com/cit.university.ccs/posts/congratulations-to-monching-desierto-bscs-4-for-winning-first-place-this-is-actu/4672417976143014/',
    image: '/cit-featured-4.jpg',
    imageAlt: 'CIT CCS Facebook Post - IT Olympics Java Winner',
    sourceLabel: 'CIT University CCS \u00B7 Facebook',
    title: 'Java Programming Champion \u2014 IT Olympics',
    description: 'Congratulations to Monching Desierto (BSCS-4) for winning First Place (First Runner-Up) in the Java Programming Competition during the IT Olympics. CCS is proud of your achievement!',
  },
  {
    href: 'https://web.facebook.com/CITUniversity/posts/ppc-2018-series-three-of-fivelet-us-get-to-know-half-50-out-of-100-of-the-studen/2308734745823533/',
    image: '/cit-featured-3.jpg',
    imageAlt: 'CIT University Facebook Post - PPC 2018',
    sourceLabel: 'CIT University \u00B7 Facebook',
    title: 'PPC 2018 \u2014 Team Introduction',
    description: 'Introducing the second team of First Year students, PPC Team 4 \u2014 part of the PPC 2018 Series highlighting the next generation of student leaders and innovators at Cebu Institute of Technology - University.',
  },
  {
    href: 'https://web.facebook.com/monchingbdesierto/posts/pfbid084M2TB9RL773Y31mWCWy3wCb4SFBH1H9Z86343MvsTHVKWFeNqHuBNbSmuA6QNEil',
    sourceLabel: 'Monching Desierto \u00B7 Facebook',
    title: 'Personal Achievement Spotlight',
    description: 'Highlighting personal milestones, projects, and achievements in software development, AI exploration, and academic excellence.',
  },
];
---

<section class="section" id="featured">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title">As <span class="gradient-text">Featured</span></h2>
      <p class="section-subtitle">Press and media mentions</p>
    </div>
    <div class="featured-grid">
      {items.map((item, i) => (
        <a href={item.href} target="_blank" rel="noopener noreferrer" class="featured-card reveal" class:list={{ 'reveal-delay-1': i > 0 }}>
          <div class="featured-media">
            {item.image ? (
              <>
                <img src={item.image} alt={item.imageAlt ?? ''} loading="lazy" />
                <div class="featured-overlay">
                  <span class="featured-play-pill">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    View Post
                  </span>
                </div>
              </>
            ) : (
              <div class="featured-media-fallback">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" opacity="0.25"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </div>
            )}
          </div>
          <div class="featured-body">
            <div class="featured-source">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              <span>{item.sourceLabel}</span>
            </div>
            <h3 class="featured-title">{item.title}</h3>
            <p class="featured-desc">{item.description}</p>
            <span class="featured-link">
              Read more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .featured-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border: 1px solid oklch(var(--color-base-content) / 0.08);
    background: oklch(var(--color-base-200) / 0.3);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px oklch(var(--color-primary) / 0.06);
    border-color: oklch(var(--color-primary) / 0.2);
    color: inherit;
  }

  .featured-media {
    position: relative;
    overflow: hidden;
    min-height: 200px;
    background: oklch(var(--color-base-300));
  }

  .featured-media-fallback {
    width: 100%;
    height: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(var(--color-base-300));
  }

  .featured-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s;
  }

  .featured-card:hover .featured-media img {
    transform: scale(1.06);
  }

  .featured-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .featured-card:hover .featured-overlay {
    opacity: 1;
  }

  .featured-play-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    color: #1a1b26;
    font-weight: 600;
    font-size: 0.85rem;
    backdrop-filter: blur(8px);
  }

  .featured-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-source {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    opacity: 0.55;
    margin-bottom: 0.75rem;
  }

  .featured-source svg {
    color: #1877f2;
    flex-shrink: 0;
  }

  .featured-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .featured-desc {
    font-size: 0.9rem;
    opacity: 0.6;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .featured-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: oklch(var(--color-primary));
  }

  .featured-link svg {
    transition: transform 0.2s;
  }

  .featured-card:hover .featured-link svg {
    transform: translate(2px, -2px);
  }

  @media (max-width: 768px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-media { min-height: 180px; max-height: 240px; }
  }
</style>
