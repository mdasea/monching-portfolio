          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="mailto:desiertomonchingb@gmail.com" title="Email" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Monching Desierto</p>
    </div>
  </div>
</footer>

<style is:global>
  .site-footer {
    border-top: 1px solid oklch(var(--color-base-content) / 0.06);
    padding: 3rem 1.5rem 2rem;
    background: oklch(var(--color-base-200) / 0.2);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .footer-logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: oklch(var(--color-primary)) !important;
    letter-spacing: -0.05em;
    text-decoration: none;
  }

  .footer-tagline {
    font-size: 0.82rem;
    opacity: 0.45;
    margin-top: 0.5rem;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .footer-nav a {
    font-size: 0.85rem;
    opacity: 0.5;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer-nav a:hover {
    opacity: 1;
    color: oklch(var(--color-primary)) !important;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .footer-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid oklch(var(--color-base-content) / 0.08);
    opacity: 0.45;
    transition: all 0.2s;
    color: inherit !important;
  }

  .footer-socials a:hover {
    opacity: 1;
    border-color: oklch(var(--color-primary));
    color: oklch(var(--color-primary)) !important;
    background: oklch(var(--color-primary) / 0.05);
  }

  .footer-copy {
    font-size: 0.8rem;
    opacity: 0.35;
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }
    .footer-nav {
      justify-content: center;
    }
    .footer-right {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
  }
</style>
