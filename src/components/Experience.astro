---
interface Role {
  title: string;
  duration: string;
  highlights: string[];
}

interface Experience {
  company: string;
  initials: string;
  location: string;
  period: string;
  roles: Role[];
  link?: string;
  logoSrc?: string;
}

const experiences: Experience[] = [
  {
    company: 'Ease Solutions',
    initials: 'ES',
    location: 'Cebu, Philippines',
    period: 'June 2022 — Present',
    link: 'https://www.easesolutions.com/',
    logoSrc: '/easesolutions-logo.svg',
    roles: [
      {
        title: 'Software Developer',
        duration: 'March 2024 — Present',
        highlights: [
          'Developed and maintained features for easeRequirements Jira Plugin (R4J) — Data Center & Cloud — using Java 8/17, Java/Jakarta EE, Spring, React, Vue, jQuery, Atlassian SDK & Forge',
          'Consistently recognized as a top-performing developer in yearly evaluations; promoted from Junior to Mid-Level on first yearly evaluation',
          'Spearheaded migration of legacy tree structure, achieving 70-80% performance improvement on APIs in both filtered and unfiltered trees',
          'Optimized filtered tree loading time by 20% through backend enhancement before migration',
          'Successfully migrated legacy Maven codebase from Java 8 to Java 17',
          'Owned and resolved multiple backend performance issues for Jira Data Center Plugin',
          'Active participant in Agile (Scrum) — sprint planning, daily stand-ups, retrospectives, PI Planning',
          'Trusted backend developer and active member of the Backend Chapter, contributing to best practices and knowledge sharing',
          'Exposed to Git, Jira Software, BitBucket',
        ],
      },
      {
        title: 'Junior Software Developer',
        duration: 'June 2022 — February 2024',
        highlights: [
          'Developed and maintained features for easeRequirements Jira Plugin (R4J) using Java 8, Java EE, Spring, React, Vue, jQuery, and Atlassian SDK',
          'Consistently recognized as a top-performing developer; promoted to Mid-Level on first yearly evaluation',
          'Optimized filtered tree loading time by 20% through backend enhancement',
          'Active participant in Agile (Scrum) development',
          'Exposed to Git, Jira Software, BitBucket',
        ],
      },
    ],
  },
  {
    company: 'Catalyst Outsourcing Private Limited',
    initials: 'CO',
    location: 'Singapore',
    period: 'November 2025 — March 2026',
    link: 'https://catalystoutsourcing.com/',
    logoSrc: '/catalyst-logo.svg',
    roles: [
      {
        title: 'Vibe Coder',
        duration: 'November 2025 — March 2026',
        highlights: [
          'Role: Vibe Coder — built and shipped features using AI-powered development tools',
          'Tools: Lovable, Claude Code, Cursor, Playwright MCP, RESEND API, Manus AI, Lark, Tavus AI API, Heygen AI',
        ],
      },
    ],
  },
  {
    company: 'lablab.ai',
    initials: 'LA',
    location: 'Remote',
    period: 'June 2025',
    link: 'https://lablab.ai/',
    logoSrc: '/lablab-logo.png',
    roles: [
      {
        title: 'Agentic AI Developer (Hackathon Project)',
        duration: 'June 2025',
        highlights: [
          'Vibe coded a full web app project with 5 international members using Trae AI IDE and Novita AI API',
          'Led the implementation of AI IDE usage and LLM model integration across the team',
          'Established the vibe coding workflow: git branching, AI-assisted requirements planning, phase-by-phase implementation, bug fixing, and collaborative PR merging',
          'Built the entire frontend and integrated Novita AI API',
          'Demonstrated frontend features and development process to judges',
        ],
      },
    ],
  },
  {
    company: 'Southern Taiwan University of Science and Technology',
    initials: 'ST',
    location: 'Taiwan',
    period: 'April 2021 — June 2021',
    link: 'https://www.stust.edu.tw/en/',
    logoSrc: '/stust-logo.png',
    roles: [
      {
        title: 'Intern AI Researcher',
        duration: 'April 2021 — June 2021',
        highlights: [
          'Authored and published a research paper on monocular image object-depth estimation on mobile phones',
        ],
      },
    ],
  },
];
---

<section class="section" id="experience">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title">Work <span class="gradient-text">Experience</span></h2>
      <p class="section-subtitle">My professional journey so far</p>
    </div>
    <div class="timeline">
      {experiences.map((exp, i) => (
        <div class="timeline-card card-custom reveal" class:list={{ 'reveal-delay-1': i > 0 }}>
          <div class="timeline-icon">
            {exp.logoSrc
              ? <img src={exp.logoSrc} alt={exp.company} class="timeline-logo" />
              : <span>{exp.initials}</span>
            }
          </div>
          <div class="timeline-header">
            <div class="timeline-company-row">
              <h3 class="timeline-company">
                {exp.link
                  ? <a href={exp.link} target="_blank" rel="noopener noreferrer">{exp.company}</a>
                  : exp.company
                }
              </h3>
            </div>
            <p class="timeline-meta">{exp.location} &middot; {exp.period}</p>
          </div>
          <div class="line-counter">{String(exp.roles.reduce((sum, r) => sum + r.highlights.length, 0)).padStart(2, '0')} highlights</div>
          {exp.roles.map((role) => (
            <div class="timeline-role">
              <div class="role-header">
                <h4 class="role-title">{role.title}</h4>
                <span class="role-duration">{role.duration}</span>
              </div>
              <ul class="role-highlights">
                {role.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 44px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #4f7df3, #8b5cf6, transparent);
    opacity: 0.2;
  }

  .timeline-card {
    padding: 1.75rem 1.75rem 1.75rem 5.5rem;
    background: oklch(var(--color-base-200) / 0.3);
    border: 1px solid oklch(var(--color-base-content) / 0.08);
  }

  .timeline-icon {
    position: absolute;
    left: 1rem;
    top: 1.75rem;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: oklch(var(--color-base-100));
    border: 2px solid oklch(var(--color-base-content) / 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: oklch(var(--color-primary));
    transition: all 0.3s;
    overflow: hidden;
    padding: 8px;
    z-index: 1;
  }

  .timeline-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .timeline-card:hover .timeline-icon {
    border-color: oklch(var(--color-primary));
    background: linear-gradient(135deg, oklch(var(--color-primary) / 0.12), oklch(var(--color-secondary) / 0.12));
    transform: scale(1.08);
    box-shadow: 0 0 20px oklch(var(--color-primary) / 0.15);
  }

  .timeline-header {
    margin-bottom: 0.75rem;
  }

  .timeline-company-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .timeline-company {
    font-size: 1.2rem;
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .timeline-company a {
    color: inherit;
    text-decoration: none;
  }

  .timeline-company a::after {
    content: ' \2197';
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .timeline-company a:hover {
    color: oklch(var(--color-primary));
  }

  .timeline-company a:hover::after {
    opacity: 1;
  }

  .timeline-meta {
    font-size: 0.85rem;
    opacity: 0.55;
    margin-top: 0.2rem;
  }

  .line-counter {
    position: absolute;
    right: 1rem;
    top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    opacity: 0.3;
    pointer-events: none;
  }

  .timeline-role {
    margin-bottom: 1.25rem;
  }

  .timeline-role:last-child {
    margin-bottom: 0;
  }

  .role-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .role-title {
    font-size: 1rem;
    font-weight: 600;
    color: oklch(var(--color-primary));
  }

  .role-duration {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    white-space: nowrap;
    padding: 0.15rem 0.6rem;
    border-radius: 6px;
    background: oklch(var(--color-primary) / 0.06);
    border: 1px solid oklch(var(--color-primary) / 0.12);
    color: oklch(var(--color-primary));
  }

  .role-highlights {
    list-style: none;
    padding: 0;
  }

  .role-highlights li {
    position: relative;
    padding-left: 1.5rem;
    opacity: 0.65;
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 0.4rem;
  }

  .role-highlights li::before {
    content: '>';
    font-family: var(--font-mono);
    font-weight: 700;
    position: absolute;
    left: 0;
    color: oklch(var(--color-success));
  }

  @media (max-width: 768px) {
    .timeline-card { padding: 1.5rem 1rem 1.5rem 4rem; }
    .timeline-icon { left: 0.5rem; width: 44px; height: 44px; }
    .timeline::before { left: 28px; }
    .line-counter { display: none; }
  }
</style>
