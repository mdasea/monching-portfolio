---
import { getCollection } from 'astro:content';

const experiences = await getCollection('experience');
---

<section class="section" id="experience">
  <div class="page">
    <div class="section-label">Experience</div>
    <div class="entry-list">
      {experiences.map(({ data }) => (
        <div class="entry">
          <div class="entry-header">
            <div class="entry-title-group">
              {data.logoSrc && (
                <span class="exp-logo-wrap">
                  <img src={data.logoSrc} alt={`${data.company} logo`} class="exp-logo" width="24" height="24" />
                </span>
              )}
              <h3 class="entry-title">
                {data.link
                  ? <a href={data.link} target="_blank" rel="noopener noreferrer">{data.company} ↗</a>
                  : data.company
                }
              </h3>
            </div>
            <span class="entry-meta">{data.location} · {data.period}</span>
          </div>
          {data.roles.map(role => (
            <div style="margin-bottom: 1rem">
              <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.4rem;">
                <span style="font-weight: 500; font-size: 0.92rem; color: var(--text-primary);">{role.title}</span>
                <span class="entry-meta">{role.duration}</span>
              </div>
              <ul style="margin: 0; padding: 0; list-style: none;">
                {role.highlights.map(h => (
                  <li style="position: relative; padding-left: 1.25rem; font-size: 0.9rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 0.25rem;">{h}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .exp-logo-wrap {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    overflow: hidden;
  }

  .exp-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
</style>
